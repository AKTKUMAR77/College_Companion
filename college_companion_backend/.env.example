# Flask runtime
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

# Comma-separated origins for CORS
# Example:
# CORS_ORIGINS=https://college-companion.web.app,https://your-custom-domain.com
CORS_ORIGINS=https://college-companion.web.app

# Admin login config
ADMIN_EMPLOYEE_ID=000000
ADMIN_PASSWORD=change-this-to-a-strong-secret

# Set to 1 only for local debugging if ADMIN_PASSWORD is unset.
ALLOW_INSECURE_DEFAULT_ADMIN=0
